# TensorRag Backend Environment Configuration

# Frontend Configuration
FRONTEND_ORIGIN=http://localhost:3000

# Local Storage (fallback)
STORAGE_DIR=./storage
DEFAULT_USER_ID=default

# Modal Configuration
MODAL_ENABLED=true

# S3-Compatible Storage (AWS S3, Cloudflare R2, MinIO, etc.)
S3_ENABLED=false
S3_ENDPOINT=  # For R2: https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET=tensorrag
S3_ACCESS_KEY=your_access_key_here
S3_SECRET_KEY=your_secret_key_here
S3_REGION=us-east-1  # Use "auto" for Cloudflare R2

# IAM Authentication
IAM_VALIDATION_ENDPOINT=https://iam.api.poridhi.io/auth/validate-token

# Compute Credits System
# Get your CF_TOKEN from the Cloudflare dashboard
CF_TOKEN=your-cloudflare-token
# Set to true to disable credit deduction (for development/testing)
DISABLE_COMPUTE_CREDITS=false
# Cloudflare Adminer API URL (can be overridden by environment variable)
CF_ADMINER_API_URL=https://tensorcode-cf-worker.poridhiaccess.workers.dev/api/compute/

# Modal (configured via modal CLI)
MODAL_TOKEN_ID=...
MODAL_TOKEN_SECRET=...